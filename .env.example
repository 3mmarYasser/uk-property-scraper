# ---------------------------------------------------------------------------
# Database (Postgres) — matches docker-compose.yml
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://ukps:ukps@localhost:5433/ukps?schema=public"

# ---------------------------------------------------------------------------
# Redis (BullMQ) — matches docker-compose.yml
# ---------------------------------------------------------------------------
REDIS_HOST="localhost"
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_PORT=3001
# Comma-separated origins allowed to call the API (the dashboard).
CORS_ORIGIN="http://localhost:3000"
# Pipeline is considered "stale/down" if no successful run within this many minutes.
PIPELINE_MAX_AGE_MINUTES=720

# ---------------------------------------------------------------------------
# Scraper behaviour
# ---------------------------------------------------------------------------
# OnTheMarket location slug to crawl, e.g. "london", "manchester", "bristol".
SCRAPE_LOCATION="london"
# Max search-result pages to crawl per run (keep small for demos).
SCRAPE_MAX_PAGES=2
# How many listing jobs a worker processes concurrently.
SCRAPE_CONCURRENCY=2
# Politeness: max listing jobs processed per interval (ms) per worker.
SCRAPE_RATE_MAX=5
SCRAPE_RATE_DURATION_MS=10000
# Run headless Chromium (true in prod/CI; set false to watch it locally).
PLAYWRIGHT_HEADLESS=true
# Optional outbound proxy, e.g. "http://user:pass@host:port". Leave blank to disable.
PROXY_URL=""

# Cron schedule for the recurring crawl (default: every 6 hours). Empty = disabled.
SCRAPE_CRON="0 */6 * * *"

# ---------------------------------------------------------------------------
# Dashboard (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"
